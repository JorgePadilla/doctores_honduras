<div class="max-w-5xl mx-auto">
  <!-- Header -->
  <div class="flex flex-wrap items-center justify-between gap-3 mb-6">
    <div class="flex items-center gap-3">
      <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Estadísticas</h1>
      <span class="px-3 py-1 text-xs font-medium rounded-full bg-sky-50 dark:bg-sky-900/30 text-sky-700 dark:text-sky-400"><%= @tier.capitalize %></span>
    </div>
    <div class="flex flex-wrap items-center gap-2">
      <div class="flex gap-1 bg-gray-100 dark:bg-slate-800 rounded-lg p-1">
        <% { 7 => "7 días", 30 => "30 días", 90 => "90 días", 365 => "1 año" }.each do |d, label| %>
          <%= link_to label, estadisticas_path(days: d),
              class: "px-3 py-1.5 text-sm font-medium rounded-md transition-colors #{@days == d ? 'bg-white dark:bg-slate-700 text-sky-600 dark:text-sky-400 shadow-sm' : 'text-gray-500 dark:text-slate-400 hover:text-gray-700 dark:hover:text-slate-200'}" %>
        <% end %>
      </div>
      <%= link_to estadisticas_path(format: :csv, days: @days), class: "inline-flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium rounded-lg border border-gray-300 dark:border-slate-600 text-gray-700 dark:text-slate-300 hover:bg-gray-50 dark:hover:bg-slate-700 transition-colors" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
        CSV
      <% end %>
      <button type="button" data-controller="print" data-action="print#now" class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium rounded-lg border border-gray-300 dark:border-slate-600 text-gray-700 dark:text-slate-300 hover:bg-gray-50 dark:hover:bg-slate-700 transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"/></svg>
        Imprimir / PDF
      </button>
    </div>
  </div>

  <!-- Summary -->
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-6">
    <div class="bg-white dark:bg-slate-800 rounded-xl shadow-md dark:shadow-slate-900/50 p-6">
      <p class="text-sm font-medium text-gray-500 dark:text-slate-400">Visitas esta semana</p>
      <div class="flex items-end gap-2 mt-1">
        <p class="text-3xl font-bold text-gray-900 dark:text-white"><%= @analytics.views_this_week %></p>
        <% if (trend = @analytics.weekly_trend_pct) %>
          <span class="mb-1 inline-flex items-center text-sm font-medium <%= trend >= 0 ? 'text-green-600 dark:text-green-400' : 'text-red-600 dark:text-red-400' %>"><%= trend >= 0 ? "▲" : "▼" %> <%= trend.abs %>%</span>
        <% end %>
      </div>
      <p class="text-xs text-gray-500 dark:text-slate-400 mt-1">vs. <%= @analytics.views_last_week %> la semana anterior</p>
    </div>
    <div class="bg-white dark:bg-slate-800 rounded-xl shadow-md dark:shadow-slate-900/50 p-6">
      <p class="text-sm font-medium text-gray-500 dark:text-slate-400">Visitas en el período</p>
      <div class="flex items-end gap-2 mt-1">
        <p class="text-3xl font-bold text-sky-600 dark:text-sky-400"><%= @analytics.views_in_range %></p>
        <span class="mb-1"><%= delta_badge(@analytics.views_in_range, @previous.views_in_range) %></span>
      </div>
      <p class="text-xs text-gray-500 dark:text-slate-400 mt-1">últimos <%= @days %> días · vs. período anterior</p>
    </div>
    <div class="bg-white dark:bg-slate-800 rounded-xl shadow-md dark:shadow-slate-900/50 p-6">
      <p class="text-sm font-medium text-gray-500 dark:text-slate-400">Visitas totales</p>
      <p class="text-3xl font-bold text-gray-900 dark:text-white mt-1"><%= @analytics.total_views %></p>
      <p class="text-xs text-gray-500 dark:text-slate-400 mt-1">histórico</p>
    </div>
  </div>

  <!-- More metrics -->
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 mb-6">
    <div class="bg-white dark:bg-slate-800 rounded-xl shadow-md dark:shadow-slate-900/50 p-6">
      <p class="text-sm font-medium text-gray-500 dark:text-slate-400">Visitantes únicos</p>
      <div class="flex items-end gap-2 mt-1">
        <p class="text-2xl font-bold text-gray-900 dark:text-white"><%= @analytics.unique_visitors %></p>
        <span class="mb-1"><%= delta_badge(@analytics.unique_visitors, @previous.unique_visitors) %></span>
      </div>
    </div>
    <div class="bg-white dark:bg-slate-800 rounded-xl shadow-md dark:shadow-slate-900/50 p-6">
      <p class="text-sm font-medium text-gray-500 dark:text-slate-400">Conversión a contacto</p>
      <p class="text-2xl font-bold text-gray-900 dark:text-white mt-1"><%= @analytics.conversion_rate %>%</p>
      <p class="text-xs text-gray-500 dark:text-slate-400 mt-1">de las vistas hacen clic</p>
    </div>
    <div class="bg-white dark:bg-slate-800 rounded-xl shadow-md dark:shadow-slate-900/50 p-6">
      <p class="text-sm font-medium text-gray-500 dark:text-slate-400">Tasa de reserva</p>
      <p class="text-2xl font-bold text-gray-900 dark:text-white mt-1"><%= @analytics.booking_rate %>%</p>
      <p class="text-xs text-gray-500 dark:text-slate-400 mt-1">de las vistas reservan</p>
    </div>
    <div class="bg-white dark:bg-slate-800 rounded-xl shadow-md dark:shadow-slate-900/50 p-6">
      <p class="text-sm font-medium text-gray-500 dark:text-slate-400">Cuándo te visitan</p>
      <p class="text-lg font-bold text-gray-900 dark:text-white mt-1"><%= @analytics.busiest_weekday || "—" %></p>
      <p class="text-xs text-gray-500 dark:text-slate-400 mt-1">Hora pico: <%= @analytics.busiest_hour || "—" %></p>
    </div>
  </div>

  <!-- Trend chart -->
  <% series = @analytics.views_by_period %>
  <% max = [ (series.map { |_l, c| c }.max || 0), 1 ].max %>
  <div class="bg-white dark:bg-slate-800 rounded-xl shadow-md dark:shadow-slate-900/50 p-6 mb-6">
    <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Tendencia de visitas</h2>
    <% if series.any? { |_l, c| c > 0 } %>
      <div class="flex items-end gap-1 h-40">
        <% series.each do |label, count| %>
          <div class="flex-1 flex flex-col justify-end items-center h-full group" title="<%= label %>: <%= count %> visita(s)">
            <div class="w-full max-w-[26px] mx-auto bg-sky-400 dark:bg-sky-500 rounded-t group-hover:bg-sky-500 dark:group-hover:bg-sky-400 transition-all" style="height: <%= (count.to_f / max * 100).round(1) %>%"></div>
          </div>
        <% end %>
      </div>
      <div class="flex justify-between text-[10px] text-gray-400 dark:text-slate-500 mt-2">
        <span><%= series.first&.first %></span>
        <span><%= series[series.length / 2]&.first %></span>
        <span><%= series.last&.first %></span>
      </div>
    <% else %>
      <p class="text-sm text-gray-500 dark:text-slate-400">Aún sin visitas en el período.</p>
    <% end %>
  </div>

  <!-- Basic breakdowns (Profesional + Elite) -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
    <%= render "shared/bar_list", title: "Cómo te encuentran", data: @analytics.sources_breakdown, empty: "Aún sin datos de origen." %>
    <%= render "shared/bar_list", title: "Dispositivos", data: @analytics.by_device, empty: "Aún sin datos de dispositivo." %>
  </div>

  <% if @tier == "elite" %>
    <!-- Advanced (Elite) -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
      <%= render "shared/bar_list", title: "Departamentos / regiones", data: @analytics.by_region, empty: "Aún sin datos de ubicación." %>
      <%= render "shared/bar_list", title: "Ciudades", data: @analytics.by_city, empty: "Aún sin datos de ubicación." %>
    </div>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
      <%= render "shared/bar_list", title: "Sitios que te refieren", data: @analytics.top_referrers, empty: "Sin referidos (tráfico directo)." %>
      <%= render "shared/bar_list", title: "Clicks de contacto", data: @analytics.contact_clicks, empty: "Aún sin clicks de contacto." %>
    </div>
    <div class="bg-white dark:bg-slate-800 rounded-xl shadow-md dark:shadow-slate-900/50 p-6">
      <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Reservas</h2>
      <div class="grid grid-cols-2 gap-4">
        <div class="text-center p-4 rounded-lg bg-gray-50 dark:bg-slate-700/40">
          <p class="text-2xl font-bold text-gray-900 dark:text-white"><%= @analytics.bookings_started %></p>
          <p class="text-xs text-gray-500 dark:text-slate-400 mt-1">Reservas iniciadas</p>
        </div>
        <div class="text-center p-4 rounded-lg bg-gray-50 dark:bg-slate-700/40">
          <p class="text-2xl font-bold text-green-600 dark:text-green-400"><%= @analytics.bookings_completed %></p>
          <p class="text-xs text-gray-500 dark:text-slate-400 mt-1">Reservas completadas</p>
        </div>
      </div>
    </div>
  <% else %>
    <!-- Upsell to Elite -->
    <div class="bg-gradient-to-r from-sky-500 to-sky-600 rounded-xl shadow-md p-6 text-white">
      <h2 class="text-lg font-bold mb-1">Estadísticas avanzadas con el plan Elite</h2>
      <p class="text-sm opacity-90 mb-3">Descubre de qué departamentos y ciudades te visitan, qué sitios te refieren, y el detalle de clics de contacto y reservas.</p>
      <%= link_to "Mejorar a Elite", settings_subscription_path, class: "inline-block bg-white text-sky-600 font-medium px-4 py-2 rounded-full hover:bg-sky-50 transition-colors" %>
    </div>
  <% end %>

  <p class="mt-6 text-xs text-gray-400 dark:text-slate-500">
    Los datos de ubicación, origen y dispositivo se recopilan de forma agregada y anónima desde que se activó la analítica.
  </p>
</div>
