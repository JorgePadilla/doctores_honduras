<div class="max-w-6xl mx-auto">
  <!-- Page header -->
  <div class="flex flex-wrap items-center justify-between gap-3 mb-6">
    <div class="flex items-center gap-3">
      <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Analítica</h1>
      <span class="px-3 py-1 text-xs font-medium rounded-full bg-sky-50 dark:bg-sky-900/30 text-sky-700 dark:text-sky-400">Admin</span>
    </div>
    <%# Range selector %>
    <div class="flex gap-1 bg-gray-100 dark:bg-slate-800 rounded-lg p-1">
      <% { 7 => "7 días", 30 => "30 días", 90 => "90 días", 365 => "1 año" }.each do |d, label| %>
        <%= link_to label, admin_analytics_path(days: d),
            class: "px-3 py-1.5 text-sm font-medium rounded-md transition-colors #{@days == d ? 'bg-white dark:bg-slate-700 text-sky-600 dark:text-sky-400 shadow-sm' : 'text-gray-500 dark:text-slate-400 hover:text-gray-700 dark:hover:text-slate-200'}" %>
      <% end %>
    </div>
  </div>

  <%= render "admin/dashboard/nav", active: :analytics %>

  <% if IpGeolocator.available? == false %>
    <div class="mb-6 p-3 bg-yellow-50 dark:bg-yellow-900/20 border border-yellow-200 dark:border-yellow-800 rounded-lg text-sm text-yellow-800 dark:text-yellow-300">
      Geolocalización desactivada: falta el archivo <code>db/GeoLite2-City.mmdb</code> (MaxMind). Las columnas de país/ciudad estarán vacías hasta que se agregue.
    </div>
  <% end %>

  <!-- KPIs -->
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 mb-6">
    <% kpis = [
         ["Visitas", @analytics.total_visits, "sky"],
         ["Visitantes únicos", @analytics.unique_visitors, "green"],
         ["Visitas con sesión", @analytics.logged_in_visits, "purple"],
         ["Búsquedas", @funnel[:searches], "amber"]
       ] %>
    <% kpi_accent = { "sky" => "text-sky-600 dark:text-sky-400", "green" => "text-green-600 dark:text-green-400", "purple" => "text-purple-600 dark:text-purple-400", "amber" => "text-amber-600 dark:text-amber-400" } %>
    <% kpis.each do |label, value, accent| %>
      <div class="bg-white dark:bg-slate-800 rounded-xl shadow-md dark:shadow-slate-900/50 p-6">
        <p class="text-sm font-medium text-gray-500 dark:text-slate-400"><%= label %></p>
        <p class="text-2xl font-bold mt-1 <%= kpi_accent[accent] %>"><%= number_with_delimiter(value) %></p>
      </div>
    <% end %>
  </div>

  <!-- Funnel -->
  <div class="bg-white dark:bg-slate-800 rounded-xl shadow-md dark:shadow-slate-900/50 p-6 mb-6">
    <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Embudo de conversión</h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      <% [
           ["Vistas de perfil", @funnel[:profile_views]],
           ["Clicks de contacto", @funnel[:contact_clicks]],
           ["Reservas iniciadas", @funnel[:bookings_started]],
           ["Reservas completadas", @funnel[:bookings_completed]]
         ].each do |label, value| %>
        <div class="text-center p-4 rounded-lg bg-gray-50 dark:bg-slate-700/40">
          <p class="text-2xl font-bold text-gray-900 dark:text-white"><%= number_with_delimiter(value) %></p>
          <p class="text-xs text-gray-500 dark:text-slate-400 mt-1"><%= label %></p>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Acquisition -->
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-6">
    <%= render "shared/bar_list", title: "Dominios de origen", data: @analytics.top_referring_domains, empty: "Sin referidos (tráfico directo)." %>
    <%= render "shared/bar_list", title: "Páginas de entrada", data: @analytics.top_landing_pages %>
    <%= render "shared/bar_list", title: "Fuentes UTM", data: @analytics.top_utm_sources, empty: "Sin campañas UTM." %>
  </div>

  <!-- Geo -->
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-6">
    <%= render "shared/bar_list", title: "Países", data: @analytics.by_country %>
    <%= render "shared/bar_list", title: "Departamentos / regiones", data: @analytics.by_region %>
    <%= render "shared/bar_list", title: "Ciudades", data: @analytics.by_city %>
  </div>

  <!-- Technology -->
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-6">
    <%= render "shared/bar_list", title: "Dispositivos", data: @analytics.by_device %>
    <%= render "shared/bar_list", title: "Navegadores", data: @analytics.by_browser %>
    <%= render "shared/bar_list", title: "Sistemas operativos", data: @analytics.by_os %>
  </div>

  <!-- Top entities -->
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-6">
    <%= render "shared/bar_list", title: "Top doctores", data: @analytics.top_doctors %>
    <%= render "shared/bar_list", title: "Top establecimientos", data: @analytics.top_establishments %>
    <%= render "shared/bar_list", title: "Top proveedores", data: @analytics.top_suppliers %>
  </div>

  <!-- Recent visits -->
  <div class="bg-white dark:bg-slate-800 rounded-xl shadow-md dark:shadow-slate-900/50 overflow-hidden">
    <h2 class="text-lg font-semibold text-gray-900 dark:text-white p-6 pb-4">Visitas recientes</h2>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200 dark:divide-slate-700">
        <thead>
          <tr>
            <% ["Fecha", "Ubicación", "Dispositivo", "Origen", "Página"].each do |h| %>
              <th class="px-6 py-3 bg-gray-50 dark:bg-slate-700/50 text-left text-xs font-medium text-gray-500 dark:text-slate-400 uppercase tracking-wider"><%= h %></th>
            <% end %>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200 dark:divide-slate-700">
          <% visits = @analytics.recent_visits %>
          <% if visits.any? %>
            <% visits.each do |v| %>
              <tr class="hover:bg-gray-50 dark:hover:bg-slate-700/50 transition-colors text-sm">
                <td class="px-6 py-3 whitespace-nowrap text-gray-500 dark:text-slate-400"><%= v.started_at&.strftime("%d/%m %H:%M") %></td>
                <td class="px-6 py-3 whitespace-nowrap text-gray-700 dark:text-slate-300"><%= [v.city, v.region, v.country].compact_blank.join(", ").presence || "—" %></td>
                <td class="px-6 py-3 whitespace-nowrap text-gray-500 dark:text-slate-400"><%= [v.device_type, v.browser].compact_blank.join(" · ").presence || "—" %></td>
                <td class="px-6 py-3 whitespace-nowrap text-gray-500 dark:text-slate-400"><%= v.referring_domain.presence || (v.utm_source.presence) || "Directo" %></td>
                <td class="px-6 py-3 text-gray-500 dark:text-slate-400 max-w-xs truncate"><%= v.landing_page %></td>
              </tr>
            <% end %>
          <% else %>
            <td colspan="5" class="px-6 py-8 text-center text-gray-500 dark:text-slate-400">Sin visitas registradas en el período.</td>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
