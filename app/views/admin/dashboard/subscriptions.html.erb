<div class="max-w-6xl mx-auto">
  <!-- Page header -->
  <div class="flex flex-wrap items-center justify-between gap-3 mb-6">
    <div class="flex items-center gap-3">
      <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Gestión de Suscripciones</h1>
      <span class="px-3 py-1 text-xs font-medium rounded-full bg-sky-50 dark:bg-sky-900/30 text-sky-700 dark:text-sky-400">Admin</span>
    </div>
    <span class="text-sm text-gray-500 dark:text-slate-400 truncate"><%= Current.user.email %></span>
  </div>

  <%= render "admin/dashboard/nav", active: :subscriptions %>

  <!-- Stats -->
  <% subs = @subscriptions || [] %>
  <% active_subs = subs.select { |s| s.status == "active" } %>
  <% monthly_revenue = active_subs.sum { |s| s.subscription_plan&.price || 0 } %>
  <div class="bg-white dark:bg-slate-800 rounded-xl shadow-md dark:shadow-slate-900/50 p-6 mb-6">
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
      <div class="text-center">
        <p class="text-sm font-medium text-gray-500 dark:text-slate-400">Total Suscripciones</p>
        <p class="text-2xl font-bold text-gray-900 dark:text-white"><%= subs.size %></p>
      </div>
      <div class="text-center">
        <p class="text-sm font-medium text-gray-500 dark:text-slate-400">Activas</p>
        <p class="text-2xl font-bold text-green-600 dark:text-green-400"><%= active_subs.size %></p>
      </div>
      <div class="text-center">
        <p class="text-sm font-medium text-gray-500 dark:text-slate-400">Canceladas</p>
        <p class="text-2xl font-bold text-red-600 dark:text-red-400"><%= subs.count { |s| s.status == "canceled" } %></p>
      </div>
      <div class="text-center">
        <p class="text-sm font-medium text-gray-500 dark:text-slate-400">Ingreso Mensual</p>
        <p class="text-2xl font-bold text-purple-600 dark:text-purple-400">$<%= monthly_revenue %></p>
      </div>
    </div>
  </div>

  <!-- Subscriptions Table -->
  <div class="bg-white dark:bg-slate-800 rounded-xl shadow-md dark:shadow-slate-900/50 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200 dark:divide-slate-700">
        <thead>
          <tr>
            <th class="px-6 py-3 bg-gray-50 dark:bg-slate-700/50 text-left text-xs font-medium text-gray-500 dark:text-slate-400 uppercase tracking-wider">Usuario</th>
            <th class="px-6 py-3 bg-gray-50 dark:bg-slate-700/50 text-left text-xs font-medium text-gray-500 dark:text-slate-400 uppercase tracking-wider">Plan</th>
            <th class="px-6 py-3 bg-gray-50 dark:bg-slate-700/50 text-left text-xs font-medium text-gray-500 dark:text-slate-400 uppercase tracking-wider">Estado</th>
            <th class="px-6 py-3 bg-gray-50 dark:bg-slate-700/50 text-left text-xs font-medium text-gray-500 dark:text-slate-400 uppercase tracking-wider">Inicio</th>
            <th class="px-6 py-3 bg-gray-50 dark:bg-slate-700/50 text-left text-xs font-medium text-gray-500 dark:text-slate-400 uppercase tracking-wider">Fin</th>
            <th class="px-6 py-3 bg-gray-50 dark:bg-slate-700/50 text-left text-xs font-medium text-gray-500 dark:text-slate-400 uppercase tracking-wider">Precio</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200 dark:divide-slate-700">
          <% if subs.present? %>
            <% subs.each do |subscription| %>
              <tr class="hover:bg-gray-50 dark:hover:bg-slate-700/50 transition-colors">
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="flex items-center">
                    <div class="w-8 h-8 bg-gray-200 dark:bg-slate-600 rounded-full flex items-center justify-center">
                      <span class="text-sm font-medium text-gray-700 dark:text-slate-300"><%= subscription.user.email[0].upcase %></span>
                    </div>
                    <div class="ml-4">
                      <div class="text-sm font-medium text-gray-900 dark:text-white"><%= subscription.user.email %></div>
                    </div>
                  </div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 dark:text-white">
                  <%= subscription.subscription_plan&.name || 'Sin plan' %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <% case subscription.status %>
                  <% when 'active' %>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 dark:bg-green-900/30 text-green-800 dark:text-green-300">
                      Activa
                    </span>
                  <% when 'canceled' %>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 dark:bg-red-900/30 text-red-800 dark:text-red-300">
                      Cancelada
                    </span>
                  <% when 'past_due' %>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 dark:bg-yellow-900/30 text-yellow-800 dark:text-yellow-300">
                      Vencida
                    </span>
                  <% else %>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 dark:bg-slate-600 text-gray-800 dark:text-slate-300">
                      <%= subscription.status %>
                    </span>
                  <% end %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 dark:text-slate-400">
                  <%= subscription.current_period_start&.strftime('%d/%m/%Y') || 'N/A' %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 dark:text-slate-400">
                  <%= subscription.current_period_end&.strftime('%d/%m/%Y') || 'N/A' %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900 dark:text-white">
                  $<%= subscription.subscription_plan&.price || '0' %>
                </td>
              </tr>
            <% end %>
          <% else %>
            <tr>
              <td colspan="6" class="px-6 py-8 text-center text-gray-500 dark:text-slate-400">
                No hay suscripciones registradas
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Revenue Breakdown -->
  <div class="mt-6 grid grid-cols-1 lg:grid-cols-2 gap-6">
    <!-- Plan Distribution -->
    <div class="bg-white dark:bg-slate-800 rounded-xl shadow-md dark:shadow-slate-900/50 p-6">
      <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Distribución por Plan</h2>
      <div class="space-y-3">
        <% active_total = active_subs.size %>
        <% SubscriptionPlan.all.each do |plan| %>
          <% plan_count = active_subs.count { |s| s.subscription_plan_id == plan.id } %>
          <% if plan_count > 0 %>
            <div class="flex justify-between items-center">
              <span class="text-sm text-gray-600 dark:text-slate-400"><%= plan.name %></span>
              <span class="text-sm font-medium text-gray-900 dark:text-white"><%= plan_count %> usuarios</span>
            </div>
            <div class="w-full bg-gray-200 dark:bg-slate-600 rounded-full h-2">
              <div class="bg-sky-500 h-2 rounded-full" style="width: <%= active_total > 0 ? (plan_count.to_f / active_total * 100).round : 0 %>%"></div>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>

    <!-- Monthly Revenue -->
    <div class="bg-white dark:bg-slate-800 rounded-xl shadow-md dark:shadow-slate-900/50 p-6">
      <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Ingresos por Plan</h2>
      <div class="space-y-3">
        <% SubscriptionPlan.all.each do |plan| %>
          <% plan_count = active_subs.count { |s| s.subscription_plan_id == plan.id } %>
          <% plan_revenue = plan_count * plan.price %>
          <% if plan_revenue > 0 %>
            <div class="flex justify-between items-center">
              <span class="text-sm text-gray-600 dark:text-slate-400"><%= plan.name %></span>
              <span class="text-sm font-medium text-gray-900 dark:text-white">$<%= plan_revenue %></span>
            </div>
            <div class="w-full bg-gray-200 dark:bg-slate-600 rounded-full h-2">
              <div class="bg-green-600 h-2 rounded-full" style="width: <%= monthly_revenue > 0 ? (plan_revenue.to_f / monthly_revenue * 100).round : 0 %>%"></div>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>
</div>
