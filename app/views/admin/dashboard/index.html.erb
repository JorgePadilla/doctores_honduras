<div class="max-w-6xl mx-auto">
  <!-- Page header -->
  <div class="flex flex-wrap items-center justify-between gap-3 mb-6">
    <div class="flex items-center gap-3">
      <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Panel de Control</h1>
      <span class="px-3 py-1 text-xs font-medium rounded-full bg-sky-50 dark:bg-sky-900/30 text-sky-700 dark:text-sky-400">Admin</span>
    </div>
    <span class="text-sm text-gray-500 dark:text-slate-400 truncate"><%= Current.user.email %></span>
  </div>

  <%= render "admin/dashboard/nav", active: :dashboard %>

  <!-- Overview stat cards -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-6">
    <% stats = [
         { label: "Total Usuarios", value: @users_count, sub: "<span class=\"text-green-600 dark:text-green-400 font-medium\">+#{@new_users_this_week}</span> esta semana".html_safe, accent: "sky",
           icon: "M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" },
         { label: "Total Doctores", value: @doctors_count, sub: "<span class=\"text-green-600 dark:text-green-400 font-medium\">+#{@new_doctors_this_week}</span> esta semana".html_safe, accent: "green",
           icon: "M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" },
         { label: "Suscripciones Activas", value: @active_subscriptions, sub: "Ingreso mensual: $#{@monthly_revenue}", accent: "purple",
           icon: "M19 21l-7-5-7 5V5a2 2 0 012-2h10a2 2 0 012 2v16z" },
         { label: "Perfiles con Imagen", value: "#{@completion_rate}%", sub: "#{@doctors_with_images}/#{@doctors_count} con imagen", accent: "amber",
           icon: "M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" }
       ] %>
    <% accent_classes = {
         "sky"    => "bg-sky-100 dark:bg-sky-900/30 text-sky-600 dark:text-sky-400",
         "green"  => "bg-green-100 dark:bg-green-900/30 text-green-600 dark:text-green-400",
         "purple" => "bg-purple-100 dark:bg-purple-900/30 text-purple-600 dark:text-purple-400",
         "amber"  => "bg-amber-100 dark:bg-amber-900/30 text-amber-600 dark:text-amber-400"
       } %>
    <% stats.each do |s| %>
      <div class="bg-white dark:bg-slate-800 rounded-xl shadow-md dark:shadow-slate-900/50 p-6 hover:shadow-lg transition-all">
        <div class="flex items-start justify-between">
          <div class="min-w-0">
            <p class="text-sm font-medium text-gray-500 dark:text-slate-400 truncate"><%= s[:label] %></p>
            <p class="text-2xl font-bold text-gray-900 dark:text-white mt-1"><%= s[:value] %></p>
            <p class="text-xs text-gray-500 dark:text-slate-400 mt-1"><%= s[:sub] %></p>
          </div>
          <div class="p-3 rounded-full <%= accent_classes[s[:accent]] %> flex-shrink-0">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= s[:icon] %>"></path>
            </svg>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Quick actions + system status -->
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-6">
    <!-- Quick Actions -->
    <div class="lg:col-span-2 bg-white dark:bg-slate-800 rounded-xl shadow-md dark:shadow-slate-900/50 p-6">
      <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Acciones Rápidas</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <% actions = [
             { title: "Gestionar Doctores", desc: "Activar/desactivar perfiles", cta: "Ir a Doctores", path: admin_doctors_path, accent: "sky",
               icon: "M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.5 2.5 0 11-5 0 2.5 2.5 0 015 0z" },
             { title: "Ver Usuarios", desc: "Gestionar cuentas de usuario", cta: "Ir a Usuarios", path: admin_users_path, accent: "green",
               icon: "M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" },
             { title: "Suscripciones", desc: "Ver estado de suscripciones", cta: "Ir a Suscripciones", path: admin_subscriptions_path, accent: "purple",
               icon: "M19 21l-7-5-7 5V5a2 2 0 012-2h10a2 2 0 012 2v16z" },
             { title: "Estadísticas", desc: "Ver crecimiento y métricas", cta: "Ver Estadísticas", path: admin_dashboard_path, accent: "amber",
               icon: "M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" }
           ] %>
        <% action_wrap = {
             "sky"    => "bg-sky-50 dark:bg-sky-900/20 border-sky-200 dark:border-sky-800 hover:bg-sky-100 dark:hover:bg-sky-900/30",
             "green"  => "bg-green-50 dark:bg-green-900/20 border-green-200 dark:border-green-800 hover:bg-green-100 dark:hover:bg-green-900/30",
             "purple" => "bg-purple-50 dark:bg-purple-900/20 border-purple-200 dark:border-purple-800 hover:bg-purple-100 dark:hover:bg-purple-900/30",
             "amber"  => "bg-amber-50 dark:bg-amber-900/20 border-amber-200 dark:border-amber-800 hover:bg-amber-100 dark:hover:bg-amber-900/30"
           } %>
        <% action_icon = {
             "sky" => "bg-sky-500", "green" => "bg-green-500", "purple" => "bg-purple-500", "amber" => "bg-amber-500"
           } %>
        <% action_link = {
             "sky"    => "text-sky-700 dark:text-sky-300 bg-sky-100 dark:bg-sky-900/40 hover:bg-sky-200 dark:hover:bg-sky-900/60",
             "green"  => "text-green-700 dark:text-green-300 bg-green-100 dark:bg-green-900/40 hover:bg-green-200 dark:hover:bg-green-900/60",
             "purple" => "text-purple-700 dark:text-purple-300 bg-purple-100 dark:bg-purple-900/40 hover:bg-purple-200 dark:hover:bg-purple-900/60",
             "amber"  => "text-amber-700 dark:text-amber-300 bg-amber-100 dark:bg-amber-900/40 hover:bg-amber-200 dark:hover:bg-amber-900/60"
           } %>
        <% actions.each do |a| %>
          <div class="border rounded-lg p-4 transition-colors <%= action_wrap[a[:accent]] %>">
            <div class="flex items-center">
              <div class="w-10 h-10 <%= action_icon[a[:accent]] %> rounded-full flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= a[:icon] %>"></path>
                </svg>
              </div>
              <div class="ml-4">
                <h3 class="text-sm font-semibold text-gray-900 dark:text-white"><%= a[:title] %></h3>
                <p class="text-xs text-gray-600 dark:text-slate-400"><%= a[:desc] %></p>
              </div>
            </div>
            <%= link_to a[:cta], a[:path], class: "mt-3 inline-flex items-center px-3 py-1 text-xs font-medium rounded-lg #{action_link[a[:accent]]}" %>
          </div>
        <% end %>
      </div>
    </div>

    <!-- System Status -->
    <div class="bg-white dark:bg-slate-800 rounded-xl shadow-md dark:shadow-slate-900/50 p-6">
      <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Estado del Sistema</h2>
      <div class="space-y-4">
        <% active_pct = @doctors_count > 0 ? [((@doctors_count - @hidden_profiles).to_f / @doctors_count * 100).round, 100].min : 0 %>
        <div class="flex justify-between items-center">
          <span class="text-sm font-medium text-gray-600 dark:text-slate-400">Perfiles Activos</span>
          <span class="text-sm font-medium text-green-600 dark:text-green-400"><%= @doctors_count - @hidden_profiles %>/<%= @doctors_count %></span>
        </div>
        <div class="w-full bg-gray-200 dark:bg-slate-600 rounded-full h-2">
          <div class="bg-green-500 h-2 rounded-full" style="width: <%= active_pct %>%"></div>
        </div>

        <div class="flex justify-between items-center">
          <span class="text-sm font-medium text-gray-600 dark:text-slate-400">Perfiles Completos</span>
          <span class="text-sm font-medium text-sky-600 dark:text-sky-400"><%= @completion_rate %>%</span>
        </div>
        <div class="w-full bg-gray-200 dark:bg-slate-600 rounded-full h-2">
          <div class="bg-sky-500 h-2 rounded-full" style="width: <%= @completion_rate %>%"></div>
        </div>

        <% subs_pct = @users_count > 0 ? [(@active_subscriptions.to_f / @users_count * 100).round, 100].min : 0 %>
        <div class="flex justify-between items-center">
          <span class="text-sm font-medium text-gray-600 dark:text-slate-400">Suscripciones Activas</span>
          <span class="text-sm font-medium text-purple-600 dark:text-purple-400"><%= @active_subscriptions %></span>
        </div>
        <div class="w-full bg-gray-200 dark:bg-slate-600 rounded-full h-2">
          <div class="bg-purple-500 h-2 rounded-full" style="width: <%= subs_pct %>%"></div>
        </div>
      </div>

      <% if @hidden_profiles > 0 || @incomplete_profiles > 0 %>
        <div class="mt-4 p-3 bg-yellow-50 dark:bg-yellow-900/20 border border-yellow-200 dark:border-yellow-800 rounded-lg">
          <div class="flex items-center">
            <svg class="w-4 h-4 text-yellow-600 dark:text-yellow-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"></path>
            </svg>
            <div class="ml-2">
              <p class="text-sm font-medium text-yellow-800 dark:text-yellow-300">Acciones Pendientes</p>
              <p class="text-xs text-yellow-600 dark:text-yellow-400">
                <% if @hidden_profiles > 0 %><%= @hidden_profiles %> perfiles ocultos<% end %>
                <% if @incomplete_profiles > 0 %><% if @hidden_profiles > 0 %> y <% end %><%= @incomplete_profiles %> incompletos<% end %>
              </p>
            </div>
          </div>
        </div>
      <% else %>
        <div class="mt-4 p-3 bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded-lg">
          <div class="flex items-center">
            <svg class="w-4 h-4 text-green-600 dark:text-green-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <div class="ml-2">
              <p class="text-sm font-medium text-green-800 dark:text-green-300">Todo en orden</p>
              <p class="text-xs text-green-600 dark:text-green-400">No hay acciones pendientes</p>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Recent activity -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <!-- Recent Users -->
    <div class="bg-white dark:bg-slate-800 rounded-xl shadow-md dark:shadow-slate-900/50 p-6">
      <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Usuarios Recientes</h2>
      <div class="space-y-3">
        <% @recent_users.each do |user| %>
          <div class="flex items-center justify-between py-2 border-b border-gray-100 dark:border-slate-700 last:border-0">
            <div class="flex items-center min-w-0">
              <div class="w-8 h-8 bg-gray-200 dark:bg-slate-700 rounded-full flex items-center justify-center flex-shrink-0">
                <span class="text-sm font-medium text-gray-700 dark:text-slate-300"><%= user.email[0].upcase %></span>
              </div>
              <div class="ml-3 min-w-0">
                <p class="text-sm font-medium text-gray-900 dark:text-white truncate"><%= user.email %></p>
                <p class="text-xs text-gray-500 dark:text-slate-400">Registrado: <%= time_ago_in_words(user.created_at) %> atrás</p>
              </div>
            </div>
            <% if user.admin? %>
              <span class="ml-2 px-2.5 py-0.5 text-xs font-medium bg-sky-50 dark:bg-sky-900/30 text-sky-700 dark:text-sky-400 rounded-full flex-shrink-0">Admin</span>
            <% end %>
          </div>
        <% end %>
      </div>
      <%= link_to "Ver todos los usuarios", admin_users_path, class: "mt-4 inline-block text-sm font-medium text-sky-600 dark:text-sky-400 hover:underline" %>
    </div>

    <!-- Recent Doctors -->
    <div class="bg-white dark:bg-slate-800 rounded-xl shadow-md dark:shadow-slate-900/50 p-6">
      <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Doctores Recientes</h2>
      <div class="space-y-3">
        <% @recent_doctors.each do |doctor| %>
          <div class="flex items-center justify-between py-2 border-b border-gray-100 dark:border-slate-700 last:border-0">
            <div class="flex items-center min-w-0">
              <% if doctor.image_url.present? %>
                <%= image_tag doctor.image_thumb_url.presence || doctor.image_url, loading: "lazy", class: "w-8 h-8 rounded-full object-cover flex-shrink-0" %>
              <% else %>
                <div class="w-8 h-8 bg-gray-200 dark:bg-slate-700 rounded-full flex items-center justify-center flex-shrink-0">
                  <span class="text-sm font-medium text-gray-700 dark:text-slate-300"><%= doctor.name[0].upcase %></span>
                </div>
              <% end %>
              <div class="ml-3 min-w-0">
                <p class="text-sm font-medium text-gray-900 dark:text-white truncate"><%= doctor.name %></p>
                <p class="text-xs text-gray-500 dark:text-slate-400 truncate"><%= doctor.specialty&.name %></p>
              </div>
            </div>
            <% if doctor.hidden? %>
              <span class="ml-2 px-2.5 py-0.5 text-xs font-medium bg-yellow-100 dark:bg-yellow-900/30 text-yellow-800 dark:text-yellow-300 rounded-full flex-shrink-0">Oculto</span>
            <% end %>
          </div>
        <% end %>
      </div>
      <%= link_to "Ver todos los doctores", admin_doctors_path, class: "mt-4 inline-block text-sm font-medium text-sky-600 dark:text-sky-400 hover:underline" %>
    </div>
  </div>
</div>
