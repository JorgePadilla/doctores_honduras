<div class="max-w-6xl mx-auto">
  <!-- Page header -->
  <div class="flex flex-wrap items-center justify-between gap-3 mb-6">
    <div class="flex items-center gap-3">
      <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Gestión de Doctores</h1>
      <span class="px-3 py-1 text-xs font-medium rounded-full bg-sky-50 dark:bg-sky-900/30 text-sky-700 dark:text-sky-400">Admin</span>
    </div>
    <span class="text-sm text-gray-500 dark:text-slate-400 truncate"><%= Current.user.email %></span>
  </div>

  <%= render "admin/dashboard/nav", active: :doctors %>

  <!-- Stats -->
  <% total = @doctors&.size || 0 %>
  <% active_count = @doctors&.count { |d| !d.hidden? } || 0 %>
  <% hidden_count = total - active_count %>
  <% with_image = @doctors&.count { |d| d.image_url.present? } || 0 %>
  <div class="bg-white dark:bg-slate-800 rounded-xl shadow-md dark:shadow-slate-900/50 p-6 mb-6">
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
      <div class="text-center">
        <p class="text-sm font-medium text-gray-500 dark:text-slate-400">Total Doctores</p>
        <p class="text-2xl font-bold text-gray-900 dark:text-white"><%= total %></p>
      </div>
      <div class="text-center">
        <p class="text-sm font-medium text-gray-500 dark:text-slate-400">Perfiles Activos</p>
        <p class="text-2xl font-bold text-green-600 dark:text-green-400"><%= active_count %></p>
      </div>
      <div class="text-center">
        <p class="text-sm font-medium text-gray-500 dark:text-slate-400">Perfiles Ocultos</p>
        <p class="text-2xl font-bold text-yellow-600 dark:text-yellow-400"><%= hidden_count %></p>
      </div>
      <div class="text-center">
        <p class="text-sm font-medium text-gray-500 dark:text-slate-400">Con Imagen</p>
        <p class="text-2xl font-bold text-sky-600 dark:text-sky-400"><%= with_image %></p>
      </div>
    </div>
  </div>

  <!-- Doctors Table -->
  <div class="bg-white dark:bg-slate-800 rounded-xl shadow-md dark:shadow-slate-900/50 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200 dark:divide-slate-700">
        <thead>
          <tr>
            <th class="px-6 py-3 bg-gray-50 dark:bg-slate-700/50 text-left text-xs font-medium text-gray-500 dark:text-slate-400 uppercase tracking-wider">Doctor</th>
            <th class="px-6 py-3 bg-gray-50 dark:bg-slate-700/50 text-left text-xs font-medium text-gray-500 dark:text-slate-400 uppercase tracking-wider">Especialización</th>
            <th class="px-6 py-3 bg-gray-50 dark:bg-slate-700/50 text-left text-xs font-medium text-gray-500 dark:text-slate-400 uppercase tracking-wider">Ubicación</th>
            <th class="px-6 py-3 bg-gray-50 dark:bg-slate-700/50 text-left text-xs font-medium text-gray-500 dark:text-slate-400 uppercase tracking-wider">Usuario</th>
            <th class="px-6 py-3 bg-gray-50 dark:bg-slate-700/50 text-left text-xs font-medium text-gray-500 dark:text-slate-400 uppercase tracking-wider">Estado</th>
            <th class="px-6 py-3 bg-gray-50 dark:bg-slate-700/50 text-left text-xs font-medium text-gray-500 dark:text-slate-400 uppercase tracking-wider">Acciones</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200 dark:divide-slate-700">
          <% if @doctors.present? %>
            <% @doctors.each do |doctor| %>
              <tr class="hover:bg-gray-50 dark:hover:bg-slate-700/50 transition-colors">
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="flex items-center">
                    <% if doctor.image_url.present? %>
                      <img src="<%= doctor.image_thumb_url.presence || doctor.image_url %>" alt="<%= doctor.name %>" loading="lazy" class="w-10 h-10 rounded-full object-cover" />
                    <% else %>
                      <div class="w-10 h-10 bg-gray-200 dark:bg-slate-600 rounded-full flex items-center justify-center">
                        <span class="text-sm font-medium text-gray-700 dark:text-slate-300"><%= doctor.name[0].upcase %></span>
                      </div>
                    <% end %>
                    <div class="ml-4">
                      <div class="text-sm font-medium text-gray-900 dark:text-white"><%= doctor.name %></div>
                      <div class="text-sm text-gray-500 dark:text-slate-400"><%= doctor.medical_license %></div>
                    </div>
                  </div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 dark:text-slate-400">
                  <%= doctor.specialty&.name %>
                  <% if doctor.subspecialty.present? %>
                    <br><span class="text-xs text-gray-400 dark:text-slate-500"><%= doctor.subspecialty.name %></span>
                  <% end %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 dark:text-slate-400">
                  <%= doctor.city&.name %>, <%= doctor.department&.name %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 dark:text-slate-400">
                  <%= doctor.user.email %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <% if doctor.hidden? %>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 dark:bg-yellow-900/30 text-yellow-800 dark:text-yellow-300">
                      Oculto
                    </span>
                  <% else %>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 dark:bg-green-900/30 text-green-800 dark:text-green-300">
                      Activo
                    </span>
                  <% end %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                  <%= form_with url: admin_toggle_doctor_visibility_path(doctor), method: :post, class: "inline-flex items-center", data: { turbo: true } do |form| %>
                    <button type="submit" class="relative inline-flex h-6 w-11 flex-shrink-0 cursor-pointer rounded-full border-2 border-transparent transition-colors duration-200 ease-in-out focus:outline-none focus:ring-2 focus:ring-sky-500 focus:ring-offset-2 <%= doctor.hidden? ? 'bg-gray-200 dark:bg-slate-600' : 'bg-sky-500' %>">
                      <span class="sr-only"><%= doctor.hidden? ? 'Activar' : 'Desactivar' %></span>
                      <span aria-hidden="true" class="pointer-events-none inline-block h-5 w-5 transform rounded-full bg-white shadow ring-0 transition duration-200 ease-in-out <%= doctor.hidden? ? 'translate-x-0' : 'translate-x-5' %>"></span>
                    </button>
                    <span class="ml-2 text-sm font-medium text-gray-700 dark:text-slate-300">
                      <%= doctor.hidden? ? 'Desactivado' : 'Activado' %>
                    </span>
                  <% end %>
                  <%= link_to "Ver", doctor_path(doctor), class: "ml-4 text-sky-600 dark:text-sky-400 hover:underline", target: "_blank" %>
                </td>
              </tr>
            <% end %>
          <% else %>
            <tr>
              <td colspan="6" class="px-6 py-8 text-center text-gray-500 dark:text-slate-400">
                No hay doctores registrados
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
