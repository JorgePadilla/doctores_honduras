<%#
  Admin section tabs. Pass the active tab key:
    render "admin/dashboard/nav", active: :dashboard   # :dashboard | :users | :doctors | :subscriptions
%>
<% tabs = [
     [:dashboard,     "Dashboard",     admin_dashboard_path],
     [:analytics,     "Analítica",     admin_analytics_path],
     [:users,         "Usuarios",      admin_users_path],
     [:doctors,       "Doctores",      admin_doctors_path],
     [:subscriptions, "Suscripciones", admin_subscriptions_path]
   ] %>
<nav class="flex flex-wrap gap-1 border-b border-gray-200 dark:border-slate-700 mb-6">
  <% tabs.each do |key, label, path| %>
    <% if key == active %>
      <%= link_to label, path, class: "px-4 py-2.5 -mb-px text-sm font-medium text-sky-600 dark:text-sky-400 border-b-2 border-sky-500" %>
    <% else %>
      <%= link_to label, path, class: "px-4 py-2.5 -mb-px text-sm font-medium text-gray-500 dark:text-slate-400 border-b-2 border-transparent hover:text-gray-700 dark:hover:text-slate-200 hover:border-gray-300 dark:hover:border-slate-600 transition-colors" %>
    <% end %>
  <% end %>
</nav>
