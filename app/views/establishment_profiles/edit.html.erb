<div class="container mx-auto px-4 py-8 max-w-3xl">
  <h1 class="text-2xl font-bold text-gray-800 dark:text-white mb-6">Editar Establecimiento</h1>

  <%= form_with model: @establishment, url: establishment_profile_path, method: :patch, class: "space-y-6" do |f| %>
    <%= render "shared/image_upload_field",
        form: f,
        attr: :logo_file,
        current_url: @establishment.logo_url,
        title: "Logo",
        subtitle: "Logotipo del establecimiento — PNG, JPG o WebP hasta 5MB" %>

    <%= render "shared/image_upload_field",
        form: f,
        attr: :building_image_file,
        current_url: @establishment.building_image_url,
        title: "Foto del edificio",
        subtitle: "Fotografía de la fachada — PNG, JPG o WebP hasta 5MB" %>

    <div class="bg-white dark:bg-slate-800 rounded-xl shadow-md dark:shadow-slate-900/50 border border-gray-200 dark:border-slate-700 p-6">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <%= f.label :name, "Nombre", class: "block text-sm font-medium text-gray-700 dark:text-slate-300" %>
          <%= f.text_field :name, class: "mt-1 block w-full border border-gray-300 dark:bg-slate-700 dark:border-slate-600 dark:text-white rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-sky-500 focus:border-sky-500 sm:text-sm", required: true %>
        </div>
        <div>
          <%= f.label :phone, "Teléfono", class: "block text-sm font-medium text-gray-700 dark:text-slate-300" %>
          <%= f.telephone_field :phone, class: "mt-1 block w-full border border-gray-300 dark:bg-slate-700 dark:border-slate-600 dark:text-white rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-sky-500 focus:border-sky-500 sm:text-sm" %>
        </div>
        <div>
          <%= f.label :email, "Email", class: "block text-sm font-medium text-gray-700 dark:text-slate-300" %>
          <%= f.email_field :email, class: "mt-1 block w-full border border-gray-300 dark:bg-slate-700 dark:border-slate-600 dark:text-white rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-sky-500 focus:border-sky-500 sm:text-sm" %>
        </div>
        <div>
          <%= f.label :website, "Sitio web", class: "block text-sm font-medium text-gray-700 dark:text-slate-300" %>
          <%= f.url_field :website, class: "mt-1 block w-full border border-gray-300 dark:bg-slate-700 dark:border-slate-600 dark:text-white rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-sky-500 focus:border-sky-500 sm:text-sm" %>
        </div>
        <div class="md:col-span-2">
          <%= f.label :address, "Dirección", class: "block text-sm font-medium text-gray-700 dark:text-slate-300" %>
          <%= f.text_field :address, class: "mt-1 block w-full border border-gray-300 dark:bg-slate-700 dark:border-slate-600 dark:text-white rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-sky-500 focus:border-sky-500 sm:text-sm", required: true %>
        </div>
        <div class="md:col-span-2">
          <%= f.label :map_link, "Enlace de mapa (Google Maps)", class: "block text-sm font-medium text-gray-700 dark:text-slate-300" %>
          <%= f.url_field :map_link, class: "mt-1 block w-full border border-gray-300 dark:bg-slate-700 dark:border-slate-600 dark:text-white rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-sky-500 focus:border-sky-500 sm:text-sm" %>
        </div>
        <div>
          <%= f.label :department_id, "Departamento", class: "block text-sm font-medium text-gray-700 dark:text-slate-300" %>
          <%= f.select :department_id,
                      options_for_select(@departments.map { |d| [d.name, d.id] }, @establishment.department_id),
                      { include_blank: "Selecciona un departamento" },
                      { class: "mt-1 block w-full border border-gray-300 dark:bg-slate-700 dark:border-slate-600 dark:text-white rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-sky-500 focus:border-sky-500 sm:text-sm" } %>
        </div>
        <div>
          <%= f.label :city_id, "Ciudad", class: "block text-sm font-medium text-gray-700 dark:text-slate-300" %>
          <%= f.select :city_id,
                      options_for_select(@cities.map { |c| [c.name, c.id] }, @establishment.city_id),
                      { include_blank: "Selecciona una ciudad" },
                      { class: "mt-1 block w-full border border-gray-300 dark:bg-slate-700 dark:border-slate-600 dark:text-white rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-sky-500 focus:border-sky-500 sm:text-sm" } %>
        </div>
        <div class="md:col-span-2">
          <%= f.label :description, "Descripción", class: "block text-sm font-medium text-gray-700 dark:text-slate-300" %>
          <%= f.text_area :description, rows: 4, class: "mt-1 block w-full border border-gray-300 dark:bg-slate-700 dark:border-slate-600 dark:text-white rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-sky-500 focus:border-sky-500 sm:text-sm" %>
        </div>
      </div>

      <% if @establishment.errors.any? %>
        <div class="mt-4 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-md p-4">
          <ul class="text-sm text-red-600 dark:text-red-300 list-disc list-inside">
            <% @establishment.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="flex justify-between mt-6">
        <%= link_to "Cancelar", dashboard_path, class: "py-2 px-4 border border-gray-300 dark:border-slate-600 rounded-full transition-all hover:shadow-md transform hover:scale-105 shadow-sm text-sm font-medium text-gray-700 dark:text-slate-300 bg-white dark:bg-slate-700 hover:bg-gray-50 dark:hover:bg-slate-600" %>
        <%= f.submit "Guardar Cambios", class: "py-2 px-4 border border-transparent rounded-full transition-all hover:shadow-md transform hover:scale-105 shadow-sm text-sm font-medium text-white bg-sky-500 hover:bg-sky-600 cursor-pointer" %>
      </div>
    </div>
  <% end %>
</div>
