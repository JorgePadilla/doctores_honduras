<% start_hour, end_hour = agenda_hour_bounds(@branches) %>
<% grid_h = agenda_grid_height_px(start_hour, end_hour) %>
<% hour_px = AgendaHelper::HOUR_PX %>

<div class="max-w-6xl mx-auto">
  <!-- Header -->
  <div class="flex flex-wrap justify-between items-center gap-3 mb-6">
    <div>
      <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Agenda</h1>
      <% if acting_as_secretary? %>
        <p class="text-sm text-gray-500 dark:text-slate-400 mt-1">Gestionando agenda de <%= current_doctor_profile.display_name %></p>
      <% end %>
    </div>
    <div class="flex items-center gap-2">
      <%= link_to agenda_notifications_path, class: "relative p-2 text-gray-500 dark:text-slate-400 hover:text-sky-600 dark:hover:text-sky-400 transition-colors" do %>
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
        <% if Current.user.unread_notifications_count > 0 %>
          <span class="absolute -top-1 -right-1 bg-red-500 text-white text-xs rounded-full w-5 h-5 flex items-center justify-center" data-controller="notification-badge"><%= Current.user.unread_notifications_count %></span>
        <% end %>
      <% end %>
      <%= link_to new_agenda_appointment_path, class: "inline-flex items-center bg-sky-500 hover:bg-sky-600 text-white px-5 py-2.5 rounded-full font-medium transition-all shadow-md hover:shadow-lg transform hover:scale-105" do %>
        <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
        Nueva Cita
      <% end %>
    </div>
  </div>

  <%= render "agenda/nav", active: :citas %>

  <div class="bg-white dark:bg-slate-800 rounded-xl shadow-md dark:shadow-slate-900/50 p-4 sm:p-6" data-controller="calendar" data-calendar-view-value="<%= @view %>">
    <!-- Navigation -->
    <div class="flex flex-wrap justify-between items-center gap-3 mb-6">
      <div class="flex items-center gap-1">
        <%= link_to agenda_appointments_path(date: (@view == "day" ? @date - 1.day : @date - 1.week), view: @view), class: "p-2 hover:bg-sky-50 dark:hover:bg-slate-700 rounded-lg transition-colors" do %>
          <svg class="w-5 h-5 text-gray-500 dark:text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        <% end %>
        <h2 class="text-base sm:text-lg font-semibold text-gray-900 dark:text-white px-1 min-w-0">
          <% if @view == "day" %>
            <%= I18n.l(@date, format: :long) %>
          <% else %>
            <%= I18n.l(@week_start, format: :long) %> – <%= I18n.l(@week_start + 6.days, format: :long) %>
          <% end %>
        </h2>
        <%= link_to agenda_appointments_path(date: (@view == "day" ? @date + 1.day : @date + 1.week), view: @view), class: "p-2 hover:bg-sky-50 dark:hover:bg-slate-700 rounded-lg transition-colors" do %>
          <svg class="w-5 h-5 text-gray-500 dark:text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <% end %>
        <%= link_to "Hoy", agenda_appointments_path(date: Date.current, view: @view), class: "ml-2 px-3 py-1.5 text-sm border border-sky-500 text-sky-600 dark:text-sky-400 rounded-full hover:bg-sky-50 dark:hover:bg-sky-900/20 font-medium transition-all" %>
      </div>
      <div class="flex bg-gray-100 dark:bg-slate-700 rounded-full p-1">
        <%= link_to "Semana", agenda_appointments_path(date: @date, view: "week"), class: "px-4 py-1.5 rounded-full text-sm font-medium transition-all #{@view == 'week' ? 'bg-white dark:bg-slate-600 text-sky-600 dark:text-sky-400 shadow-sm' : 'text-gray-500 dark:text-slate-400 hover:text-gray-700 dark:hover:text-slate-300'}" %>
        <%= link_to "Día", agenda_appointments_path(date: @date, view: "day"), class: "px-4 py-1.5 rounded-full text-sm font-medium transition-all #{@view == 'day' ? 'bg-white dark:bg-slate-600 text-sky-600 dark:text-sky-400 shadow-sm' : 'text-gray-500 dark:text-slate-400 hover:text-gray-700 dark:hover:text-slate-300'}" %>
      </div>
    </div>

    <% if @branches.empty? %>
      <div class="text-center py-12">
        <svg class="mx-auto w-12 h-12 text-gray-300 dark:text-slate-600 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0H5m14 0h2M5 21H3m4-14h.01M11 7h.01M7 11h.01M11 11h.01"/></svg>
        <p class="text-gray-600 dark:text-slate-300 font-medium">Aún no tienes sucursales configuradas</p>
        <p class="text-sm text-gray-400 dark:text-slate-500 mt-1">Agrega una sucursal con horarios en tu perfil para poder agendar citas.</p>
      </div>

    <% elsif @view == "day" %>
      <!-- DAY VIEW -->
      <div class="flex">
        <div class="w-14 flex-shrink-0">
          <% (start_hour...end_hour).each do |h| %>
            <div style="height:<%= hour_px %>px" class="relative">
              <span class="absolute -top-2 right-2 text-xs text-gray-400 dark:text-slate-500"><%= format("%02d:00", h) %></span>
            </div>
          <% end %>
        </div>
        <div class="relative flex-1 border-l border-gray-200 dark:border-slate-700 cursor-pointer" style="height:<%= grid_h %>px"
             data-calendar-target="track" data-date="<%= @date %>" data-start-hour="<%= start_hour %>" data-hour-px="<%= hour_px %>"
             data-action="click->calendar#newAt">
          <% (0..(end_hour - start_hour)).each do |i| %>
            <div class="absolute left-0 right-0 border-t border-gray-100 dark:border-slate-700/60" style="top:<%= i * hour_px %>px"></div>
          <% end %>
          <% if @date == Date.current && (npx = now_line_px(start_hour, end_hour)) %>
            <div class="absolute left-0 right-0 z-20 flex items-center" style="top:<%= npx %>px">
              <span class="w-2 h-2 rounded-full bg-red-500 -ml-1"></span>
              <span class="flex-1 h-px bg-red-500"></span>
            </div>
          <% end %>
          <% layout_appointments(@appointments).each do |item| %>
            <% appt = item[:appt] %>
            <%= link_to agenda_appointment_path(appt),
                style: "top:#{appt_top_px(appt, start_hour)}px; height:#{appt_height_px(appt)}px; #{lane_style(item[:lane], item[:lanes], 6)}",
                class: "absolute z-10 rounded-lg border-l-4 #{appt.status_classes[:border]} #{appt.status_classes[:bg]} #{appt.status_classes[:text]} px-2 py-0.5 leading-tight overflow-hidden hover:shadow-md hover:z-30 transition-all" do %>
              <% if appt.duration_minutes >= 45 %>
                <p class="text-xs font-semibold truncate"><%= appt.start_time.strftime("%H:%M") %> · <%= appt.patient_name %></p>
                <p class="text-xs opacity-80 truncate"><%= appt.reason.presence || appt.doctor_branch.name %></p>
              <% else %>
                <p class="text-xs truncate"><span class="font-semibold"><%= appt.start_time.strftime("%H:%M") %></span> <%= appt.patient_name %></p>
              <% end %>
            <% end %>
          <% end %>
        </div>
      </div>

    <% else %>
      <!-- WEEK VIEW -->
      <div class="overflow-x-auto">
        <div class="min-w-[44rem]">
          <!-- Day headers -->
          <div class="flex">
            <div class="w-14 flex-shrink-0"></div>
            <% (0..6).each do |i| %>
              <% day = @week_start + i.days %>
              <% today = day == Date.current %>
              <%= link_to agenda_appointments_path(date: day, view: "day"), class: "flex-1 text-center py-2 hover:bg-sky-50 dark:hover:bg-slate-700/50 transition-colors rounded-t-lg" do %>
                <div class="text-xs font-medium text-gray-500 dark:text-slate-400 uppercase"><%= I18n.l(day, format: :short).split.first %></div>
                <div class="mt-1 mx-auto text-sm font-bold <%= today ? 'bg-sky-500 text-white rounded-full w-7 h-7 flex items-center justify-center' : 'text-gray-900 dark:text-white' %>"><%= day.day %></div>
              <% end %>
            <% end %>
          </div>
          <!-- Grid -->
          <div class="flex" style="height:<%= grid_h %>px">
            <div class="w-14 flex-shrink-0">
              <% (start_hour...end_hour).each do |h| %>
                <div style="height:<%= hour_px %>px" class="relative">
                  <span class="absolute -top-2 right-2 text-xs text-gray-400 dark:text-slate-500"><%= format("%02d:00", h) %></span>
                </div>
              <% end %>
            </div>
            <% (0..6).each do |i| %>
              <% day = @week_start + i.days %>
              <% today = day == Date.current %>
              <div class="relative flex-1 border-l border-gray-200 dark:border-slate-700 cursor-pointer <%= today ? 'bg-sky-50/40 dark:bg-sky-900/10' : '' %>"
                   data-calendar-target="track" data-date="<%= day %>" data-start-hour="<%= start_hour %>" data-hour-px="<%= hour_px %>"
                   data-action="click->calendar#newAt">
                <% (0..(end_hour - start_hour)).each do |j| %>
                  <div class="absolute left-0 right-0 border-t border-gray-100 dark:border-slate-700/60" style="top:<%= j * hour_px %>px"></div>
                <% end %>
                <% if today && (npx = now_line_px(start_hour, end_hour)) %>
                  <div class="absolute left-0 right-0 z-20 h-px bg-red-500" style="top:<%= npx %>px"></div>
                <% end %>
                <% layout_appointments(@appointments_by_date[day] || []).each do |item| %>
                  <% appt = item[:appt] %>
                  <%= link_to agenda_appointment_path(appt),
                      style: "top:#{appt_top_px(appt, start_hour)}px; height:#{appt_height_px(appt)}px; #{lane_style(item[:lane], item[:lanes], 2)}",
                      class: "absolute z-10 rounded-md border-l-2 #{appt.status_classes[:border]} #{appt.status_classes[:bg]} #{appt.status_classes[:text]} px-1 py-0.5 leading-none overflow-hidden hover:shadow-md hover:z-30 transition-all" do %>
                    <p class="text-[11px] leading-tight truncate"><span class="font-semibold"><%= appt.start_time.strftime("%H:%M") %></span> <%= appt.patient_name %></p>
                  <% end %>
                <% end %>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
